# ============================================================
# Social Ads — Zenite Tech
# Renomeie este arquivo para .env e preencha com suas credenciais
# NUNCA commite o arquivo .env
# ============================================================

# ── Banco de Dados (MySQL 8+ ou TiDB Cloud) ─────────────────
# Formato: mysql://usuario:senha@host:porta/banco
DATABASE_URL=

# ── Autenticacao JWT ────────────────────────────────────────
# Gere com: openssl rand -hex 64
JWT_SECRET=

# ── Google Ads API ──────────────────────────────────────────
# App OAuth: console.cloud.google.com -> APIs & Services -> Credentials
# Renovar via: https://developers.google.com/oauthplayground/
# Escopo: https://www.googleapis.com/auth/adwords
GOOGLE_ADS_CLIENT_ID=
GOOGLE_ADS_CLIENT_SECRET=
GOOGLE_ADS_REFRESH_TOKEN=
GOOGLE_ADS_DEVELOPER_TOKEN=
# Exemplo de formato: 3003291643 (sem hifens)
GOOGLE_ADS_CUSTOMER_ID=
GOOGLE_ADS_LOGIN_CUSTOMER_ID=
# Data de criacao do token (YYYY-MM-DD) — usado para alertas de expiracao
GOOGLE_ADS_TOKEN_CREATED_AT=
# Mesma conta exposta ao frontend (RelatorioAds.tsx)
VITE_GOOGLE_ADS_CUSTOMER_ID=

# ── GA4 Data API ────────────────────────────────────────────
# Property ID do GA4 (ex: 531461479)
GA4_PROPERTY_ID=
# JSON completo da Service Account com permissao Viewer no GA4
# Gere em: console.cloud.google.com -> IAM -> Service Accounts
GA4_SERVICE_ACCOUNT_JSON=

# ── Google Search Console ───────────────────────────────────
# JSON da Service Account com acesso a propriedade no Search Console
GOOGLE_SEARCH_CONSOLE_SA_JSON=

# ── Gmail API ───────────────────────────────────────────────
# Escopos necessarios: gmail.send + gmail.readonly
# Renovar via OAuth Playground com as mesmas credenciais do Google Ads
GMAIL_REFRESH_TOKEN=

# ── Meta / Instagram ────────────────────────────────────────
# Token de Pagina — gere via: https://developers.facebook.com/tools/explorer/
# Permissoes: instagram_content_publishing, instagram_basic,
#   instagram_manage_insights, pages_read_engagement
META_ADS_ACCESS_TOKEN=
META_ADS_ACCOUNT_ID=

# ── WhatsApp: Evolution API (canal principal) ───────────────
EVOLUTION_API_URL=
EVOLUTION_API_KEY=
EVOLUTION_INSTANCE_NAME=

# ── WhatsApp: Twilio (fallback) ─────────────────────────────
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_WHATSAPP_FROM=

# ── CRM / Google Sheets ─────────────────────────────────────
# ATENCAO: GOOGLE_SERVICE_ACCOUNT_KEY NAO deve ir para o frontend
# Implementar a logica de sync no servidor (server/routers/)
GOOGLE_SHEETS_ID=
GOOGLE_SERVICE_ACCOUNT_KEY=

# ── Briefing de Voz ─────────────────────────────────────────
VOXFORGE_URL=

# ── URLs internas ───────────────────────────────────────────
FRONTEND_URL=
GADS_DASHBOARD_URL=
REACT_APP_WS_URL=

# ── Integracao entre Dashboards ─────────────────────────────
# Gere com: openssl rand -hex 32
INTEGRATION_API_KEY=

# ── LLM e Storage (ambiente Manus) ──────────────────────────
BUILT_IN_FORGE_API_URL=
BUILT_IN_FORGE_API_KEY=
VITE_FRONTEND_FORGE_API_URL=
VITE_FRONTEND_FORGE_API_KEY=

# ── Manus OAuth (apenas no ambiente Manus — injetado automaticamente) ──
VITE_APP_ID=
OAUTH_SERVER_URL=
VITE_OAUTH_PORTAL_URL=
OWNER_OPEN_ID=
OWNER_NAME=

# ── Analytics (opcional — injetado pela plataforma) ─────────
VITE_ANALYTICS_ENDPOINT=
VITE_ANALYTICS_WEBSITE_ID=

# ── Seed de Admin (usado pelos scripts de seed/reset — nunca em runtime) ──
ADMIN_SEED_PASSWORD=
ADMIN_SEED_NAME=
ADMIN_SEED_EMAIL=
ADMIN_SEED_EMAILS=

# ── IDs publicos do Google Ads (nao-secretos) ──────────────
GOOGLE_ADS_MAIN_CAMPAIGN_ID=
GOOGLE_ADS_TOKEN_EXPIRES_AT=
GMAIL_TOKEN_EXPIRES_AT=
